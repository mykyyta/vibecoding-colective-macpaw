# ElevenLabs API key. Keep the real value in .env only.
ELEVENLABS_API_KEY=

# Public SSE or streamable HTTP MCP server URL.
# Example: https://example.com/mcp
ELEVENLABS_MCP_SERVER_URL=

# Display name shown in the ElevenLabs MCP integrations dashboard.
ELEVENLABS_MCP_SERVER_NAME=Vibecoding Collective MCP

# Optional description shown in ElevenLabs.
ELEVENLABS_MCP_SERVER_DESCRIPTION=Project MCP server for the Vibecoding Collective event workspace.

# ElevenLabs supports SSE and streamable HTTP transports for MCP integrations.
# Use SSE unless the server explicitly exposes a streamable HTTP MCP endpoint.
ELEVENLABS_MCP_TRANSPORT=SSE

# Safe default while testing new MCP integrations.
# Other policies can be configured later in the ElevenLabs dashboard or API.
ELEVENLABS_MCP_APPROVAL_POLICY=require_approval_all

# Optional Authorization header value for the MCP server itself.
# Do not use this for the ElevenLabs API key.
ELEVENLABS_MCP_SECRET_TOKEN=

# Optional JSON object with extra headers required by the MCP server.
# Example: {"x-project":"vibecoding"}
ELEVENLABS_MCP_REQUEST_HEADERS_JSON=

# Generic local server port for future app or MCP server prototypes.
PORT=3000
