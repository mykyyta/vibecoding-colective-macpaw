{
  "name": "vibecoding-colective",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,blue \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch src/server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "infra:plan": "scripts/infra/plan.sh",
    "infra:apply": "scripts/infra/apply.sh",
    "deploy:railway": "scripts/railway/deploy-web.sh",
    "deploy:cloudfront": "scripts/cloudfront/deploy-frontend.sh",
    "elevenlabs:mcp:create": "node scripts/elevenlabs-mcp.mjs create",
    "elevenlabs:mcp:list": "node scripts/elevenlabs-mcp.mjs list",
    "elevenlabs:mcp:tools": "node scripts/elevenlabs-mcp.mjs tools"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
